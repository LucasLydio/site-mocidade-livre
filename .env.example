# Copy this file to `.env` and fill the values.
# Netlify: set the same keys in Site settings → Environment variables.

# --- Supabase (required) ---
# Example: https://xxxxxxxxxxxxxxxxxxxx.supabase.co
# Do NOT use:
# - postgresql://... (database connection string)
# - https://db.<project-ref>.supabase.co (database host)
SUPABASE_URL=https://your-project-ref.supabase.co

# Use ONE of the keys below.
# Recommended for Netlify Functions (server-side): Service Role key (bypasses RLS).
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key
# Alternative (limited by RLS): Anonymous key.
# SUPABASE_ANON_KEY=your-supabase-anon-key

# --- Auth / JWT (required) ---
# Used to sign API tokens.
JWT_SECRET=your-long-random-secret

# Optional (defaults shown)
JWT_ISSUER=site-mocidade-livre
JWT_EXPIRES_IN=7d

# --- Storage (optional) ---
# Supabase Storage bucket for product images (default: files_upload)
STORAGE_BUCKET_FILES_UPLOAD=mocidade_livre

# --- Shop (optional) ---
# WhatsApp receiver number (digits only, with country code), e.g. 5562999999999
SHOP_WHATSAPP_NUMBER=5562999999999
